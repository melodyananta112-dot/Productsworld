rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: products
    // Fields: name (string), description (string), price (number), image (string), category (string), quantity (number), createdAt (number), updatedAt (number)
    //
    // Collection: orders
    // Fields: userId (string), items (list), total (number), status (string), address (string), phone (string), createdAt (number)
    //
    // Collection: users
    // Fields: uid (string), email (string), displayName (string), role (string), createdAt (number)
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
         (request.auth.token.email == "melody.ananta112@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidProduct(data) {
      // Basic core fields validation (required for create/update)
      return (data.get('name', '') is string && data.get('name', '').size() < 500) &&
             (data.get('price', 0) is number && data.get('price', 0) >= 0) &&
             (data.get('image', '') is string) &&
             (data.get('quantity', 0) is number) &&
             (data.get('inStock', true) is bool) &&
             (data.get('deliveryInsideDhaka', '') is string) &&
             (data.get('deliveryOutsideDhaka', '') is string);
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['userId', 'items', 'total', 'status', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.items is list && data.items.size() > 0 &&
             data.total is number && data.total >= 0 &&
             data.status in ['pending', 'processing', 'shipped', 'ready_for_delivery', 'delivered', 'cancelled'];
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'createdAt']) &&
             data.uid == request.auth.uid &&
             data.email is string &&
             data.role in ['admin', 'customer'];
    }

    function isValidSlideshowItem(data) {
      return (data.get('url', '') is string && data.get('url', '').size() > 0) &&
             (data.get('order', 0) is number) &&
             (data.get('createdAt', 0) is number);
    }

    function isValidFlashSale(data) {
      return ((data.get('bannerUrl', '') is string) || (data.get('bannerUrls', []) is list)) &&
             (data.get('endTime', 0) is number) &&
             (data.get('isActive', false) is bool) &&
             (data.get('price', 0) is number) &&
             (data.get('description', '') is string) &&
             (data.get('linkUrl', '') is string);
    }

    // Rules
    match /flash_sale/{saleId} {
      allow read: if true;
      allow create: if isAdmin() && isValidFlashSale(request.resource.data);
      allow update: if isAdmin() && isValidFlashSale(request.resource.data);
      allow delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true; // Publicly viewable
      allow create: if isAdmin() && isValidProduct(request.resource.data);
      allow update: if isAdmin() && isValidProduct(request.resource.data);
      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && isValidOrder(request.resource.data);
      allow update: if isAdmin(); // Only admin can update status
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAdmin() || isOwner(userId);
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && 
        (request.resource.data.role == 'customer' || (request.resource.data.role == 'admin' && request.auth.token.email == "melody.ananta112@gmail.com"));
      allow update: if isAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role);
    }

    match /slideshow/{itemId} {
      allow read: if true;
      allow create: if isAdmin() && isValidSlideshowItem(request.resource.data);
      allow update: if isAdmin() && isValidSlideshowItem(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
